<mvc:View
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:common="sap.suite.ui.commons"
    xmlns:macros="sap.fe.macros"
    xmlns:table="sap.fe.macros.table"
    xmlns:html="http://www.w3.org/1999/xhtml"
    controllerName="nlab.ai.comparequotation.ext.controller.ManageCompareQuotation"
>
    <Page
        id="_IDGenManageCQPage1"
        title="{LocalModel>/CompareQuotationHeader/CompativeStatementTitle}"
        floatingFooter="true"
        class="sapUiResponsivePadding--header sapUiResponsivePadding--content sapUiResponsivePadding--footer sapUiResponsivePadding--floatingFooter"
    >
        <IconTabBar
            id="_IDGenManageCQIconTabstickySubheaderBar"
            class="sapUiResponsiveContentPadding"
        >
            <items>
                <IconTabFilter
                    id="_IDGenManageCQIconTabFilter"
                    text="Quotation Comparison"
                >
                    <core:Fragment
                        id="_IDGenManageCQCreateFragment"
                        fragmentName="nlab.ai.comparequotation.ext.fragment.QuotationComparisonDisplay"
                        type="XML"
                    />
                </IconTabFilter>
                <IconTabFilter
                    id="_IDGenManageCQIconTabFilter2"
                    text="Request For Quotation"
                    visible="true"
                >
                    <!-- <VBox id="_IDGenManageCQRFQSessionVBox"> -->
                    <core:Fragment
                        id="_IDGenManageCQRFQDetailFragment"
                        fragmentName="nlab.ai.comparequotation.ext.fragment.RFQDetail"
                        type="XML"
                    />
                    <!-- </VBox> -->
                </IconTabFilter>
                <IconTabFilter
                    id="_IDGenManageCQIconTabFilterSQ"
                    text="Supplier Quotation"
                    visible="true"
                >
                    <!-- <VBox id="_IDGenManageCQRFQSessionVBox"> -->
                    <core:Fragment
                        id="_IDGenManageCQRFQDetailFragmentSQ"
                        fragmentName="nlab.ai.comparequotation.ext.fragment.SupplierQuotationDetail"
                        type="XML"
                    />
                    <!-- </VBox> -->
                </IconTabFilter>
                <IconTabFilter
                    id="_IDGenManageCQIconTabFilter3"
                    text="Workflow"
                >
                    <core:Fragment
                        id="_IDGenManageCQWorkflowFragment"
                        fragmentName="nlab.ai.comparequotation.ext.fragment.Workflow"
                        type="XML"
                    />
                </IconTabFilter>
            </items>
        </IconTabBar>

        <footer>
            <OverflowToolbar id="_IDGenManageCQOverflowToolbar">
                <ToolbarSpacer id="_IDGenManageCQToolbarSpacer" />
                <Button
                    id="_IDGenManageCQButton2"
                    visible="{LocalModel>/IsEditCompareQuotation}"
                    text="Save"
                    press=".onSaveMCQPress"
                    type="Emphasized"
                    icon=""
                />
                <Button
                    id="_IDGenManageCQButton3"
                    visible="{LocalModel>/IsEditCompareQuotation}"
                    text="Cancel"
                    press=".onCancelonMCQPress"
                    type="Default"
                    icon=""
                />
                <Button
                    id="_IDGenManageCQButtonApprove"
                    text="Approve"
                    press=".onCompareQuotationApprovePress"
                    type="Success"
                    visible="{=${LocalModel>/hasWorkflowApprovalAccess}? !${LocalModel>/IsEditCompareQuotation} :false}"
                />
                <!-- visible="{=${LocalModel>/IsEditCompareQuotation}? false:true}" -->
                <Button
                    id="_IDGenManageCQButtonReject"
                    text="Reject"
                    press=".onCompareQuotationRejectPress"
                    type="Reject"
                    visible="{=${LocalModel>/hasWorkflowApprovalAccess}? !${LocalModel>/IsEditCompareQuotation} :false}"
                />
                <!-- visible="{=${LocalModel>/IsEditCompareQuotation}? false:true}" -->
                <Button
                    id="_IDGenManageCQButton"
                    text="Edit"
                    press=".onCompareQuotationEditPress"
                    type="Emphasized"
                    visible="{=${LocalModel>/hasWorkflowApprovalEditAccess}? !${LocalModel>/IsEditCompareQuotation} :false}"
                />
                <!-- visible="{=${LocalModel>/IsEditCompareQuotation}? false:true}" -->
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>

<core:FragmentDefinition
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:macros="sap.fe.macros"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="_IDGenAORFragmentDialog"
        title="{=${LocalModel>/Workflow/WorkflowMode}=== 'APPROVE'? 'Do you want to Approve?' :'Do you want to Reject?'}"
        contentWidth='30%'
    >
        <f:SimpleForm
            id="_IDGenAORFragmentSimpleForm"
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1"
            singleContainerFullSize="false"
        >
            <f:content>
                <Label
                    id="_IDGenAORFragmentDialogLabel3"
                    text="Comment"
                    required="true"
                />
                <TextArea
                    id="_IDGenAORFragmentDialogTextArea"
                    maxLength="1000"
                    value="{LocalModel>/Workflow/Comment}"
                />
            </f:content>
        </f:SimpleForm>
        <buttons>
            <Button
                id="_IDGenAORFragmentAddButton"
                text="{=${LocalModel>/Workflow/WorkflowMode}=== 'APPROVE'? 'Approve' :'Reject'}"
                visible="{= ${LocalModel>/TermsAndConditionDialog/IsAddNewTC} ? false:true}"
                press=".onAORFragmentApproveOrRejectPress"
            />
            <Button
                id="_IDGenAORFragmentCancelButton"
                text="Cancel"
                press=".onAORFragmentCancelPress"
                visible="{= ${LocalModel>/TermsAndConditionDialog/IsAddNewTC} ? false:true}"
            />
        </buttons>
    </Dialog>
</core:FragmentDefinition>

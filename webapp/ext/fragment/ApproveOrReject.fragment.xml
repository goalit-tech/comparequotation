<core:FragmentDefinition
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:macros="sap.fe.macros"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="_IDGenAORFragmentDialog"
        title="{=${LocalModel>/Workflow/Action}=== 'APPROVED'? 'Do you want to Approve?' :'Do you want to Reject?'}"
        contentWidth='30%'
    >
        <f:SimpleForm
            id="_IDGenAORFragmentSimpleForm"
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1"
            singleContainerFullSize="false"
        >
            <f:content>
                <Label
                    id="_IDGenAORFragmentDialogLabel3"
                    text="Select Reason Code"
                    required="true"
                    visible="{= ${LocalModel>/Workflow/Action} ==='REJECTED' ? true:false}"
                />
                <ComboBox
                    selectedKey="{LocalModel>/Workflow/ReasonCode}"
                    id="_IDGenAORFragmentDialogComboBox"
                    items="{LocalModel>/Workflow/RejectionReasonData}"
                    visible="{= ${LocalModel>/Workflow/Action} ==='REJECTED' ? true:false}"
                    valueState="{LocalModel>/Workflow/ReasonCodeState}"
                >
                    <items>
                        <core:Item
                            id="_IDGenAORFragmentDialogItem"
                            text="{LocalModel>Desc}"
                            key="{LocalModel>Code}"
                        />
                    </items>
                </ComboBox>
                <Label
                    id="_IDGenAORFragmentDialogLabelComment"
                    text="Comment"
                    required="true"
                />
                <TextArea
                    id="_IDGenAORFragmentDialogTextArea"
                    maxLength="1000"
                    value="{LocalModel>/Workflow/Comment}"
                    valueState="{LocalModel>/Workflow/CommentState}"
                />
            </f:content>
        </f:SimpleForm>
        <buttons>
            <Button
                id="_IDGenAORFragmentAddButton"
                text="{=${LocalModel>/Workflow/Action}=== 'APPROVED'? 'Approve' :'Reject'}"
                visible="{= ${LocalModel>/TermsAndConditionDialog/IsAddNewTC} ? false:true}"
                type="{=${LocalModel>/Workflow/Action}=== 'APPROVED'? 'Success' :'Reject'}"
                press=".onAORFragmentApproveOrRejectPress"
            />
            <Button
                id="_IDGenAORFragmentCancelButton"
                text="Cancel"
                press=".onAORFragmentCancelPress"
                visible="{= ${LocalModel>/TermsAndConditionDialog/IsAddNewTC} ? false:true}"
            />
        </buttons>
    </Dialog>
</core:FragmentDefinition>

<core:FragmentDefinition
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:plugins="sap.m.plugins"
    xmlns:macros="sap.fe.macros"
    xmlns:common="sap.suite.ui.commons"
    xmlns:dnd="sap.ui.core.dnd"
    xmlns:core="sap.ui.core"
>
    <IconTabBar
        id="_IDGenWorkflowIconTabBar"
        class="sapUiResponsiveContentPadding"
    >
        <items>
            <IconTabFilter
                id="IconTabBarIconTabFilter1"
                text="Arrange Workflow"
                visible="{LocalModel>/IsEditCompareQuotation}"
            >
                <Table
                    id="_IDGenWorkflowDefinationTable"
                    mode="SingleSelectMaster"
                    growing="true"
                    growingThreshold="10"
                    beforeOpenContextMenu=".onBeforeOpenContextMenu"
                    items="{
			path: 'LocalModel>/WorkflowDefination',
            filters: {path: 'Rank', operator: 'GT', value1: '0'},
			sorter: {path: 'Rank', descending: false}
		}"
                    noDataText="Please arrange in sequence Number."
                >
                    <!-- filters: {path: 'SeqNo', operator: 'C', value1: 'L1'}, -->
                    <dependents>
                        <plugins:ContextMenuSetting
                            id="_IDGenWorkflowContextMenuSetting"
                            scope="Selection"
                        />
                    </dependents>
                    <headerToolbar>
                        <OverflowToolbar id="_IDGenWorkflowOverflowToolbar">
                            <Title
                                id="_IDGenWorkflowTitle"
                                text="Workflow Sequence"
                            />
                            <ToolbarSpacer id="_IDGenWorkflowToolbarSpacer" />
                            <Button
                                id="_IDGenWorkflowButton"
                                tooltip="Reset Sequence"
                                text="Reset Sequence"
                                visible="{LocalModel>/IsEditCompareQuotation}"
                                press=".ResetSequenceWorkflowPress"
                            />
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column id="_IDGenWorkflowColumnSNO">
                            <Text
                                id="_IDGenWorkflowTextCOLSNO"
                                text="Sequence No"
                            />
                        </Column>
                        <Column id="_IDGenWorkflowColumn">
                            <Text
                                id="_IDGenWorkflowText"
                                text="Stage Code"
                            />
                        </Column>
                        <Column id="_IDGenWorkflowColumn1">
                            <Text
                                id="_IDGenWorkflowText1"
                                text="Stage Name"
                            />
                        </Column>
                        <Column id="_IDGenWorkflowColumn2">
                            <Text
                                id="_IDGenWorkflowText2"
                                text="Approver Type"
                            />
                        </Column>
                        <Column id="_IDGenWorkflowColumn3">
                            <Text
                                id="_IDGenWorkflowTextAV"
                                text="Approver Value"
                            />
                        </Column>
                        <Column id="_IDGenWorkflowColumn4">
                            <Text
                                id="_IDGenWorkflowTextMADT"
                                text="Is Mandatory"
                            />
                        </Column>
                    </columns>
                    <dragDropConfig>
                        <dnd:DragInfo
                            id="_IDGenWorkflowDragInfo"
                            groupName="selected2available"
                            sourceAggregation="items"
                            enabled="{LocalModel>/IsEditCompareQuotation}"
                        />
                        <dnd:DropInfo
                            id="_IDGenWorkflowDropInfo"
                            groupName="available2selected"
                            targetAggregation="items"
                            dropPosition="Between"
                            drop=".onDropSelectedProductsTable"
                            enabled="{LocalModel>/IsEditCompareQuotation}"
                        />
                        <dnd:DragDropInfo
                            id="_IDGenWorkflowDragDropInfo"
                            sourceAggregation="items"
                            targetAggregation="items"
                            dropPosition="Between"
                            drop=".onDropSelectedProductsTable"
                            enabled="{LocalModel>/IsEditCompareQuotation}"
                        />
                    </dragDropConfig>
                    <items>
                        <ColumnListItem id="_IDGenWorkflowColumnListItem">
                            <cells>
                                <Text
                                    id="_IDGenWorkflowTextSNO"
                                    text="L-{LocalModel>SeqNo}"
                                    wrapping="false"
                                />
                                <Text
                                    id="_IDGenWorkflowText3"
                                    text="{LocalModel>StageCode}"
                                    wrapping="false"
                                />
                                <Text
                                    id="_IDGenWorkflowText4"
                                    text="{LocalModel>StageName}"
                                    wrapping="false"
                                />
                                <Text
                                    id="_IDGenWorkflowText5"
                                    text="{LocalModel>ApproverType}"
                                    wrapping="false"
                                />
                                <Text
                                    id="_IDGenWorkflowText6"
                                    text="{LocalModel>ApproverValue}"
                                    wrapping="false"
                                />
                                <CheckBox
                                    id="_IDGenWorkflowText7"
                                    editable="{LocalModel>/IsEditCompareQuotation}"
                                    selected="{LocalModel>IsMandatory}"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
                <!-- </VBox> -->
            </IconTabFilter>
            <IconTabFilter
                id="IconTabBarIconTabFilter2"
                text="Process Flow"
                visible="{=!${LocalModel>/IsEditCompareQuotation}}"
            >
                <common:ProcessFlow
                    id="processflow1"
                    scrollable="false"
                    foldedCorners="true"
                    nodePress=".onNodePress"
                    lanes="{LocalModel>/WorkflowDefination}"
                    nodes="{LocalModel>/Workflow/CurrentWorkflowTransaction}"
                >
                    <common:nodes>
                        <!-- nodeId="{LocalModel>TransactionId}" -->
                        <!-- title="{LocalModel>Action}" -->
                        <common:ProcessFlowNode
                            id="_IDGenProcessFlowNode"
                            laneId="{=String(${LocalModel>SeqNo})}"
                            nodeId="{LocalModel>id}"
                            title="L-{LocalModel>SeqNo}"
                            children="{LocalModel>children}"
                            state="{path:'LocalModel>Action',formatter:'.processFlowStateFormatter'}"
                            stateText="{path:'LocalModel>Action',formatter:'.processFlowStateTextFormatter'}"
                            texts="{path:'LocalModel>',formatter:'.processFlowTextsFormatter'}"
                        />
                    </common:nodes>
                    <common:lanes>
                        <common:ProcessFlowLaneHeader
                            id="_IDGenProcessFlowLaneHeader"
                            laneId="{=String(${LocalModel>SeqNo})}"
                            text="{LocalModel>StageName}"
                            iconSrc="{path:'LocalModel>StageCode',formatter:'.processFlowIconSrcFormatter'}"
                            position="{=${LocalModel>SeqNo}-1}"
                        />
                        <!-- iconSrc="{LocalModel>icon}" -->
                    </common:lanes>
                </common:ProcessFlow>
            </IconTabFilter>
            <IconTabFilter
                id="IconTabBarIconTabFilter3"
                text="History"
                visible="{=!${LocalModel>/IsEditCompareQuotation}}"
            >
                <Table
                    id="_IDGenWorkflowDefinationHistoryTable"
                    growing="true"
                    growingThreshold="10"
                    items="{
                        path: 'LocalModel>/Workflow/WorkFlowTransacationData/',
                        filters: {path: 'VersionNo', operator: 'GT', value1: '0'},
                        sorter: {path: 'VersionNo', descending: true}
                    }"
                    noDataText="No History"
                >
                    <columns>
                        <Column
                            id="_IDGenWorkflowHistoryDefversion"
                            width="6rem"
                        >
                            <Text
                                id="_IDGenWorkflowHistoryColumnTextDefversion"
                                text="Def Version"
                                wrapping="true"
                            />
                        </Column>
                        <Column
                            id="_IDGenWorkflowHistoryVersionNo"
                            width="6rem"
                        >
                            <Text
                                id="_IDGenWorkflowHistoryColumnTextVersionNo"
                                text="Version No"
                                wrapping="true"
                            />
                        </Column>
                        <Column
                            id="_IDGenWorkflowHistorySeqNo"
                            width="6rem"
                        >
                            <Text
                                id="_IDGenWorkflowHistoryColumnTextSeqNo"
                                text="Seq No"
                                wrapping="true"
                            />
                        </Column>
                        <Column id="_IDGenWorkflowHistoryAssignedTo">
                            <Text
                                id="_IDGenWorkflowHistoryColumnTextAssignedTo"
                                text="Assigned To"
                                wrapping="true"
                            />
                        </Column>
                        <Column id="_IDGenWorkflowHistoryApprovedBy">
                            <Text
                                id="_IDGenWorkflowHistoryColumnTextApprovedBy"
                                text="Approved By"
                                wrapping="true"
                            />
                        </Column>
                        <Column id="_IDGenWorkflowHistoryAction">
                            <Text
                                id="_IDGenWorkflowHistoryColumnTextAction"
                                text="Action"
                            />
                        </Column>
                        <Column id="_IDGenWorkflowHistoryComments">
                            <Text
                                id="_IDGenWorkflowHistoryColumnTextComments"
                                text="Comments"
                                wrapping="true"
                            />
                        </Column>
                        <Column id="_IDGenWorkflowHistoryReasonCode">
                            <Text
                                id="_IDGenWorkflowHistoryColumnTextReasonCode"
                                text="ReasonCode"
                                wrapping="true"
                            />
                        </Column>
                        <Column id="_IDGenWorkflowHistorychangedAt">
                            <Text
                                id="_IDGenWorkflowHistoryColumnTextchangedAt"
                                text="changed At"
                                wrapping="true"
                            />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem
                            id="_IDGenWorkflowHistoryColumnListItem"
                        >
                            <cells>
                                <Text
                                    id="_IDGenWorkflowHistoryTextDefversion"
                                    text="{LocalModel>Defversion}"
                                    wrapping="false"
                                />
                                <Text
                                    id="_IDGenWorkflowHistoryTextVersionNo"
                                    text="{LocalModel>VersionNo}"
                                    wrapping="false"
                                />
                                <Text
                                    id="_IDGenWorkflowHistoryTextSNO"
                                    text="L-{LocalModel>SeqNo}"
                                    wrapping="false"
                                />
                                <Text
                                    id="_IDGenWorkflowHistoryText3"
                                    text="{LocalModel>AssignedTo}"
                                    wrapping="false"
                                />
                                <Text
                                    id="_IDGenWorkflowHistoryText4"
                                    text="{LocalModel>ApprovedBy}"
                                    wrapping="false"
                                />
                                <Text
                                    id="_IDGenWorkflowHistoryText5"
                                    text="{LocalModel>Action}"
                                    wrapping="false"
                                />
                                <Text
                                    id="_IDGenWorkflowHistoryText6"
                                    text="{LocalModel>Comments}"
                                    wrapping="false"
                                />
                                <Text
                                    id="_IDGenWorkflowHistoryText7"
                                    text="{LocalModel>/ReasonCode}"
                                />
                                <Text
                                    id="_IDGenWorkflowHistoryText8"
                                    text="{LocalModel>/changedAt}"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </IconTabFilter>
        </items>
    </IconTabBar>

    <!-- selectionChange=".onRFQDialogTableRowSelectionChange" -->
</core:FragmentDefinition>
